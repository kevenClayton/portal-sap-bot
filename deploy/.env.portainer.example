# Copie para .env.portainer no Portainer (ou em deploy/.env.portainer local).
# Não commite o ficheiro real — está no .gitignore.

APP_NAME="Bot SAP"
APP_ENV=production
# Deixe vazio na primeira subida; o entrypoint gera com php artisan key:generate
APP_KEY=
APP_DEBUG=false

# URL pública que o browser usa (https + domínio real). Sem barra no fim.
APP_URL=https://exemplo.seudominio.com
APP_PORT=8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# --- MySQL (produção) ---
DB_CONNECTION=mysql
DB_HOST=mysql.exemplo.com
DB_PORT=3306
DB_DATABASE=nome_base
DB_USERNAME=usuario
DB_PASSWORD=senha_segura
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_FOREIGN_KEYS=true
# Se o servidor MySQL exige SSL, aponte para o ficheiro CA *dentro do container* (monte volume se precisar)
MYSQL_ATTR_SSL_CA=

# --- SQLite (só dev/local no compose simples) ---
# DB_CONNECTION=sqlite
# DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Se usar subdomínio e cookies, pode precisar de .seudominio.com
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# Buffer de logs em cache (sem persistir em bot_logs)
BOT_LOG_TTL_MINUTES=1440
BOT_LOG_MAX_ENTRIES=5000

# Mesmo valor que em .env.worker.portainer (token forte, ex.: openssl rand -hex 32)
WORKER_API_TOKEN=
# Hosts do SPA (sem https), separados por vírgula — deve incluir o hostname de APP_URL
SANCTUM_STATEFUL_DOMAINS=exemplo.seudominio.com,localhost,127.0.0.1

WHATSAPP_NOTIFY_URL=
WHATSAPP_NOTIFY_TOKEN=

# --- Worker (mesmo bloco no Portainer; o compose reparte para o serviço worker) ---
BOT_API_BASE=http://app:8000
SAP_BASE_URL=https://portallogistica.arcelormittal.com.br
SAP_LOGIN_URL=
SAP_DOMAIN=BMS
SAP_CLIENT=310
SAP_USER=
SAP_PASSWORD=
SAP_ODATA_EXPAND=
SAP_BATCH_USE_CHANGESET=1
BOT_INTERVAL=60
HEADLESS=1
WORKER_MIRROR_TERMINAL=1
