# Copie para .env e preencha (nunca commite .env com senhas reais)
#
# URL base do Laravel (sem barra no fim). Tem de coincidir com onde o site corre:
#   Laragon (virtual host):  http://portal-sap-bot.test   (ou o nome da pasta .test)
#   php artisan serve:       http://127.0.0.1:8000
BOT_API_BASE=http://localhost:8000
WORKER_API_TOKEN=

# Host do portal (OData e cookies), sem barra no fim
SAP_BASE_URL=https://portallogistica.arcelormittal.com.br
# Página de login: deixe vazio para usar automaticamente {SAP_BASE_URL}/my.policy
# Não use só a raiz https://host/ — o formulário fica em my.policy (BIG-IP/F5).
# SAP_LOGIN_URL=https://portallogistica.arcelormittal.com.br/my.policy
# Domínio no formulário (campo input_3)
SAP_DOMAIN=BMS
# Cliente SAP (igual ao parâmetro sap-client= na app Fiori; vazio = não enviar)
SAP_CLIENT=310

SAP_USER=
SAP_PASSWORD=

# Listagem OData: opcional $expand (ex.: RequestToNotes)
# SAP_ODATA_EXPAND=RequestToNotes

BOT_INTERVAL=60
# 1 = browser oculto (produção). 0 = janela visível para ver o login SAP (requer ambiente gráfico).
HEADLESS=1
# 1 = cada linha do terminal [robô] também é gravada no painel (Robô → actividade em tempo real). 0 = só consola.
WORKER_MIRROR_TERMINAL=1
